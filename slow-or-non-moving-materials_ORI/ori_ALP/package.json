{
	"name": "ui.s2p.mm.slonomo.mat.ori",
	"version": "0.0.1",
	"private": true,
	"sapux": true,
	"sapuxLayer": "CUSTOMER_BASE",
	"description": "",
	"keywords": [
		"ui5",
		"openui5",
		"sapui5"
	],
	"main": "webapp/index.html",
	"scripts": {
		"start": "fiori run --open \"test/flpSandbox.html?sap-client=300&sap-ui-xx-viewCache=false#masterDetail-display\"",
		"start-local": "fiori run --config ./ui5-local.yaml --open \"test/flpSandboxMockServer.html?sap-client=300&sap-ui-xx-viewCache=false#masterDetail-display\"",
		"start-noflp": "fiori run --open \"index.html?sap-client=300&sap-ui-xx-viewCache=false\"",
		"start-variants-management": "fiori run --open \"preview.html?sap-client=300&sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#preview-app\"",
		"build:app": "ui5 build --config ./ui5.yaml -a --clean-dest --include-task=generateCachebusterInfo",
		"build:template-lib": "ui5 build --config ./ui5-template.yaml -a --clean-dest --exclude-task=buildThemes --dest ./template-dist",
		"copy-template": "copyfiles -u 6 template-dist/resources/sap/suite/ui/generic/template/** dist",
		"build": "npm run build:template-lib && npm run build:app && npm run copy-template",
		"deploy": "npm run build && fiori deploy --config ui5-deploy.yaml && rimraf archive.zip",
		"deploy-config": "fiori add deploy-config",
		"start-mock": "fiori run --open \"test/flpSandboxMockServer.html?sap-client=300&sap-ui-xx-viewCache=false#masterDetail-display\"",
		"format": "prettier --write \"webapp/**/*.{js,json}\"",
		"undeploy": "npm run build && fiori undeploy --config ui5-deploy.yaml",
		"deploy-test": "npm run build && fiori deploy --config ui5-deploy.yaml --testMode true"
	},
	"devDependencies": {
		"@sap/ux-ui5-tooling": "1",
		"@ui5/cli": "^3.0.0",
		"rimraf": "3.0.2"
	},
	"dependencies": {
		"copyfiles": "^2.4.1",
		"prettier": "^3.6.2"
	}
}
